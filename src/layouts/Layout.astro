---
// src/layouts/Layout.astro
import '../styles/global.css';
import Header from '../components/ui/Header.astro';
import Footer from '../components/ui/Footer.astro';
import JsonLd from '../components/seo/JsonLd.astro'; 
import CommandPalette from '../components/ui/CommandPalette.tsx';

interface Props {
  title?: string;
  description?: string;
  isTool?: boolean; 
  features?: string[]; 
  faqs?: { question: string; answer: string }[]; 
  howTo?: { name: string; steps: { name: string; text: string }[] }; 
  slug?: string; 
  isHomepage?: boolean;
}

const { 
  title = "SyntaxSnap - Privacy-First Developer Tools",
  description = "A privacy-first suite of developer tools that run entirely in your browser. No servers. No tracking.",
  isTool = false,
  features,
  faqs,
  howTo,
  slug, 
  isHomepage = false,
} = Astro.props;

// ── 1. STRICT CANONICAL URL LOGIC (Cloudflare Pages Safe) ─────────
const siteUrl = Astro.site ? new URL(Astro.site).origin : "https://syntaxsnap.com";
let pathname = Astro.url.pathname;

if (pathname !== '/' && pathname.endsWith('/')) {
  pathname = pathname.slice(0, -1);
}
if (pathname.endsWith('.html')) {
  pathname = pathname.slice(0, -5);
}

const canonicalURL = new URL(pathname, siteUrl).toString();

// ── 2. DYNAMIC OG IMAGE ───────────────────────────────────────────
const ogImagePath = slug ? `/og/${slug}.png` : '/og-preview.jpg';
const socialImageURL = new URL(ogImagePath, siteUrl).toString();
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="preconnect" href="https://www.clarity.ms" crossorigin />
    <link rel="preconnect" href="https://c.clarity.ms" crossorigin />
    <link rel="preconnect" href="https://c.bing.com" crossorigin />
    <link rel="dns-prefetch" href="https://www.clarity.ms" />
    <link rel="dns-prefetch" href="https://c.clarity.ms" />
    <link rel="dns-prefetch" href="https://c.bing.com" />
    
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    
    <meta name="theme-color" content="#0f172a" />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SyntaxSnap" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />

    {/* SEO Schema: Now properly passing all rich snippet data */}
    <JsonLd 
      type={isTool ? 'tool' : 'website'} 
      title={title} 
      description={description} 
      url={canonicalURL} 
      features={features}
      faqs={faqs}
      howTo={howTo}      
    />
  </head>
  
  <body class="bg-slate-950 text-slate-200 min-h-screen font-sans antialiased flex flex-col selection:bg-indigo-500/30">
    <Header />
    
    <main class="w-full max-w-6xl mx-auto px-4 py-8 md:py-12 flex-1 animate-in fade-in duration-700">
      
      {/* ── BREADCRUMB HOOK ──────────────────────────────────── */}
      {Astro.slots.has('breadcrumb') && (
        <nav class="text-sm text-slate-400 mb-6 flex items-center gap-2">
          <slot name="breadcrumb" />
        </nav>
      )}

      {/* Main Page Content */}
      <slot />

    </main>

    {/* ── GLOBAL TOOL CLUSTERS (Passes PageRank across site) ─ */}
    <div class="w-full border-t border-slate-800 bg-slate-900/30">
      <div class="max-w-6xl mx-auto px-4 py-10">
        <h2 class="text-lg font-semibold text-slate-100 mb-6">Popular Developer Tools</h2>
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-sm">
          <div>
            <p class="font-medium text-slate-300 mb-3">JSON & Zod</p>
            <ul class="space-y-2 text-slate-400">
              <li><a href="/tools/json-to-zod" class="hover:text-indigo-400 transition-colors">JSON to Zod</a></li>
              <li><a href="/tools/json-schema-to-zod" class="hover:text-indigo-400 transition-colors">JSON Schema to Zod</a></li>
              <li><a href="/tools/zod-to-prompt" class="hover:text-indigo-400 transition-colors">Zod to Prompt</a></li>
            </ul>
          </div>

          <div>
            <p class="font-medium text-slate-300 mb-3">API Tools</p>
            <ul class="space-y-2 text-slate-400">
              <li><a href="/tools/openapi-to-zod" class="hover:text-indigo-400 transition-colors">OpenAPI to Zod</a></li>
              <li><a href="/tools/graphql-to-trpc" class="hover:text-indigo-400 transition-colors">GraphQL to tRPC</a></li>
              <li><a href="/tools/trpc-to-openapi" class="hover:text-indigo-400 transition-colors">tRPC to OpenAPI</a></li>
            </ul>
          </div>

          <div>
            <p class="font-medium text-slate-300 mb-3">Format & Conversion</p>
            <ul class="space-y-2 text-slate-400">
              <li><a href="/tools/sql-to-json" class="hover:text-indigo-400 transition-colors">SQL to JSON</a></li>
              <li><a href="/tools/sql-to-prisma" class="hover:text-indigo-400 transition-colors">SQL to Prisma</a></li>
              <li><a href="/tools/ts-to-json-schema" class="hover:text-indigo-400 transition-colors">TS to JSON Schema</a></li>
            </ul>
          </div>

          <div>
            <p class="font-medium text-slate-300 mb-3">Utilities</p>
            <ul class="space-y-2 text-slate-400">
              <li><a href="/tools/regex-tester" class="hover:text-indigo-400 transition-colors">Regex Tester</a></li>
              <li><a href="/tools/jwt-debugger" class="hover:text-indigo-400 transition-colors">JWT Debugger</a></li>
              <li><a href="/tools/meta-tag-generator" class="hover:text-indigo-400 transition-colors">Meta Tag Generator</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <Footer />

    {/* Analytics */}
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-QCZWS74HCP" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-QCZWS74HCP');
    </script>
    <script is:inline>
        (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", "viplajyvf3");
    </script>
    <CommandPalette client:load />
  </body>
</html>