---
// src/components/seo/JsonLd.astro
import { buildToolBreadcrumbs, extractToolName } from '../../utils/schema';

interface Props {
  type?: 'website' | 'tool';
  title: string;
  description: string;
  url: string;
  imageUrl?: string;
  features?: string[];
  /** New prop: skip base schema on homepage to prevent duplication */
  isHomepage?: boolean; 
}

const { 
  type = 'website', 
  title, 
  description, 
  url, 
  imageUrl = 'https://syntaxsnap.com/og-preview.jpg',
  features,
  isHomepage = false
} = Astro.props;

// ── Base schemas (skip if isHomepage is true) ─────────────────────
const baseSchema = !isHomepage ? [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "url": "https://syntaxsnap.com",
    "name": "SyntaxSnap",
    "alternateName": ["Syntax Snap", "DigiTekLab SyntaxSnap"],
    "publisher": { "@id": "https://syntaxsnap.com/#organization" }
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "https://syntaxsnap.com/#organization",
    "name": "SyntaxSnap",
    "url": "https://syntaxsnap.com",
    "logo": "https://syntaxsnap.com/logo.png"
  }
] : [];

// ── SoftwareApplication (tool pages only) ────────────────────────
const toolSchema = type === 'tool' ? {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": title,
  "description": description,
  "url": url,
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Web Browser",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "image": imageUrl
} : null;

// ── BreadcrumbList ─────────────────────────────────────────────
const breadcrumbSchema = type === 'tool' ? (() => {
  const toolName = extractToolName(title);
  const slug = new URL(url).pathname.split('/').filter(Boolean).pop() || '';
  return buildToolBreadcrumbs(toolName, slug);
})() : null;
---

{baseSchema.map(s => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}
{toolSchema && <script type="application/ld+json" set:html={JSON.stringify(toolSchema)} />}
{breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}