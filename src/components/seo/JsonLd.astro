---
// src/components/seo/JsonLd.astro
import {
  SITE_URL,
  SITE_NAME,
  buildFAQPage,
  buildHowTo,
  buildToolBreadcrumbs,
  extractToolName
} from '../../utils/schema';

// ── Strict TypeScript Props (Do not remove these!) ────────────
interface Props {
  type?: 'website' | 'tool';
  title: string;
  description: string;
  url: string;
  imageUrl?: string;
  features?: string[];
  faqs?: { question: string; answer: string }[];
  howTo?: { name: string; steps: { name: string; text: string }[] };
}

const {
  type = 'website',
  title,
  description,
  url,
  imageUrl,
  features,
  faqs,
  howTo
} = Astro.props;

const graph = [];

// ── 1. Base Entities (Always required for reference integrity) ─
graph.push({
  "@type": "Organization",
  "@id": `${SITE_URL}/#organization`,
  "name": SITE_NAME,
  "url": SITE_URL,
  "logo": {
    "@type": "ImageObject",
    "url": `${SITE_URL}/logo.png`
  }
});

graph.push({
  "@type": "WebSite",
  "@id": `${SITE_URL}/#website`,
  "url": SITE_URL,
  "name": SITE_NAME,
  "publisher": { "@id": `${SITE_URL}/#organization` }
});

// ── 2. The Current Page ────────────────────────────────────────
graph.push({
  "@type": "WebPage",
  "@id": `${url}#webpage`,
  "url": url,
  "name": title,
  "description": description,
  "isPartOf": { "@id": `${SITE_URL}/#website` }
});

// ── 3. Tool Specific Data ──────────────────────────────────────
if (type === 'tool') {
  // Build the base tool object
  const toolSchema: Record<string, any> = {
    "@type": "SoftwareApplication",
    "@id": `${url}#tool`,
    "name": title,
    "description": description,
    "url": url,
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Web Browser",
    "creator": { "@id": `${SITE_URL}/#organization` },
    "isPartOf": { "@id": `${SITE_URL}/#website` },
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  };

  // Safely inject optional fields without causing "undefined" errors
  if (imageUrl) toolSchema["image"] = imageUrl;
  if (features && features.length > 0) toolSchema["featureList"] = features.join(', ');

  graph.push(toolSchema);

  // Safely generate Breadcrumbs
  const toolName = extractToolName(title);
  // Strip trailing slashes before extracting the slug
  const pathname = new URL(url).pathname.replace(/\/$/, '');
  const slug = pathname.split('/').filter(Boolean).pop() || '';
  
  graph.push(buildToolBreadcrumbs(toolName, slug, url));
}

// ── 4. Rich Snippet Extensions ─────────────────────────────────
if (faqs && faqs.length > 0) {
  graph.push(buildFAQPage(faqs, url));
}

if (howTo && howTo.steps && howTo.steps.length > 0) {
  graph.push(buildHowTo(howTo.name, description, howTo.steps, url));
}
---

{/* ── is:inline is MANDATORY so Astro doesn't break the JSON ─ */}
<script type="application/ld+json" is:inline set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@graph": graph
})} />