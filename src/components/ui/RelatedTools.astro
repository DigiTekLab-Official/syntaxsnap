---
// src/components/ui/RelatedTools.astro
import { TOOLS, type Tool } from '../../config/tools';
import ToolCard from './ToolCard.astro'; // <-- Import your shared card component!

interface Props {
  currentTool: string;
}

const { currentTool } = Astro.props;

// Filter out the current tool so we don't suggest the tool they are already using
const relatedTools = TOOLS.filter((tool: Tool) => tool.id !== currentTool);
const currentToolData = TOOLS.find((t: Tool) => t.id === currentTool);

// --- NEW LOGIC: Prioritize Hero Tools for Cross-Pollination ---
// These are your highest-converting tools based on data
const heroToolIds = ['aurora-gradient', 'json-schema-to-zod', 'ai-mock-generator', 'jwt-debugger'];

// 1. Grab Hero tools first
let crossPollinated = relatedTools.filter((t: Tool) => heroToolIds.includes(t.id));

// 2. If we have less than 3 hero tools available (e.g. they are currently ON a hero tool), 
// fill the remaining slots with tools from the same category.
if (crossPollinated.length < 3) {
  const sameCategory = relatedTools.filter((t: Tool) => t.category === currentToolData?.category && !heroToolIds.includes(t.id));
  crossPollinated = [...crossPollinated, ...sameCategory];
}

// 3. Fallback: If STILL less than 3, just grab any remaining tools so the UI doesn't break
if (crossPollinated.length < 3) {
  const remainingTools = relatedTools.filter((t: Tool) => !crossPollinated.some(cp => cp.id === t.id));
  crossPollinated = [...crossPollinated, ...remainingTools];
}

// 4. Lock it to exactly 3 tools for perfect UI grid alignment
const displayTools = crossPollinated.slice(0, 3);

// Helper to format category names for the "View all" link
const categoryMap: Record<string, string> = {
  json: 'JSON & Schema',
  dev: 'Developer',
  css: 'Design & CSS',
  ai: 'AI Powered',
  data: 'Data Conversion'
};

const categoryLabel = currentToolData?.category 
  ? categoryMap[currentToolData.category] || 'Related' 
  : 'Related';
---

<section class="border-t border-slate-800 mt-20 pt-16 mb-12">
  <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-10 px-4">
    <div>
      <h2 class="text-2xl font-bold text-white mb-2 tracking-tight">Explore More Developer Tools</h2>
      <p class="text-slate-400">Boost your productivity with our other privacy-first utilities.</p>
    </div>
    
    {currentToolData?.category && (
      <a href={`/tools/category/${currentToolData.category}`} class="text-indigo-400 hover:text-indigo-300 text-sm font-medium transition-colors mb-1 md:mb-0">
        View all {categoryLabel} tools &rarr;
      </a>
    )}
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-6xl mx-auto px-4">
    {displayTools.map((tool) => (
      <ToolCard tool={tool} /> 
    ))}
  </div>
</section>