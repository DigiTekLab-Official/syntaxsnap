---
// src/components/ui/ExtensionPromo.astro
interface Props {
  context?: string; // e.g., "JSON to Zod"
}

const { context = "this tool" } = Astro.props;
const extensionLink = "https://chromewebstore.google.com/detail/syntaxsnap-developer-tool/klglanlaodgndhpcaldmoeenjepiocfi";
---

<div class="mb-10 relative overflow-hidden rounded-2xl border border-indigo-500/30 bg-indigo-500/10 p-6 shadow-inner shadow-indigo-500/20 flex flex-col md:flex-row items-start md:items-center justify-between gap-6 group">
   
   {/* Background Hover Glow */}
   <div class="absolute -top-16 -right-16 w-48 h-48 bg-indigo-500/20 rounded-full blur-3xl group-hover:bg-indigo-500/30 transition-all duration-700 pointer-events-none"></div>

   <div class="relative z-10 flex items-center gap-4">
      <div class="bg-slate-950 p-3 rounded-xl border border-slate-800 shadow-sm shrink-0">
         {/* Chrome Browser SVG Icon */}
         <svg class="w-6 h-6 text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <circle cx="12" cy="12" r="4"></circle>
            <line x1="21.17" y1="8" x2="12" y2="8"></line>
            <line x1="3.95" y1="6.06" x2="8.54" y2="14"></line>
            <line x1="10.88" y1="21.94" x2="15.46" y2="14"></line>
         </svg>
      </div>
      <div>
         <h3 class="text-slate-100 font-semibold text-base">Love using {context}? Take it everywhere.</h3>
         <p class="text-slate-400 text-sm mt-1">Get the SyntaxSnap extension. 100% free, local-first, zero tracking.</p>
      </div>
   </div>

   <a 
      href={extensionLink} 
      target="_blank" 
      rel="noopener noreferrer" 
      class="relative z-10 w-full md:w-auto text-center whitespace-nowrap px-6 py-2.5 bg-indigo-500 hover:bg-indigo-400 text-white text-sm font-bold rounded-xl shadow-md hover:shadow-indigo-500/25 transition-all focus:ring-2 focus:ring-indigo-400 focus:outline-none"
   >
      Add to Chrome
   </a>
</div>