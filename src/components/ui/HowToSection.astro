---
// src/components/ui/HowToSection.astro
import type { HowTo } from '../../data/seo/types';

interface Props {
  howTo?: HowTo;
}

const { howTo } = Astro.props;
---

{howTo && howTo.steps && howTo.steps.length > 0 && (
  <section class="mt-12 border-t border-slate-800 pt-12">
    <h2 class="text-2xl font-bold text-white mb-8">{howTo.name}</h2>
    
    <div class="relative space-y-8 before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-slate-800 before:to-transparent">
      {howTo.steps.map((step, index) => (
        <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group">
          {/* The Number Circle */}
          <div class="flex items-center justify-center w-10 h-10 rounded-full border border-slate-700 bg-slate-900 text-indigo-400 font-bold text-sm shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 ring-4 ring-slate-950 z-10">
            {index + 1}
          </div>

          {/* The Content Card */}
          <div class="w-[calc(100%-4rem)] md:w-[45%] bg-slate-900/40 border border-slate-800 p-5 rounded-2xl shadow-xl">
            <h3 class="text-slate-100 font-semibold mb-1">{step.name}</h3>
            <p class="text-sm text-slate-400 leading-relaxed">
              {step.text}
            </p>
          </div>
        </div>
      ))}
    </div>
  </section>
)}