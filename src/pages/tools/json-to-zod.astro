---
// src/pages/tools/json-to-zod.astro
import Layout from '../../layouts/Layout.astro';
import JsonConverter from '../../components/tools/JsonToZod';
import RelatedTools from '../../components/ui/RelatedTools.astro';
import FaqSection from '../../components/ui/FaqSection.astro';
import HowToSection from '../../components/ui/HowToSection.astro';
import ExtensionPromo from '../../components/ui/ExtensionPromo.astro';

// 1. Import Data
import { toolSeoData } from '../../data/seo';

const title = "JSON to Zod Converter (Instant Schema Generator) | SyntaxSnap";
const description = "Convert raw JSON objects into Zod schemas instantly. Infers types, arrays, and objects for TypeScript validation.";
const slug = "json-to-zod";

const features = [
  "Infers TypeScript types from JSON",
  "Generates Zod validation schemas",
  "Handles nested objects and arrays",
  "Local-first processing (Privacy focused)"
];

// 2. Fetch Data
const pageSeoData = toolSeoData["json-to-zod"];
---

<Layout 
  title={title} 
  description={description} 
  isTool={true} 
  slug={slug} 
  features={features}
  howTo={pageSeoData?.howTo}
  faqs={pageSeoData?.faqs}
> 

  <div class="max-w-6xl mx-auto">
    
    {/* ── BREADCRUMBS ── */}
    <Fragment slot="breadcrumb">
      <a href="/" class="hover:text-indigo-400 transition-colors">Home</a> 
      <span class="text-slate-600">/</span>
      <a href="/tools/category/json" class="hover:text-indigo-400 transition-colors">JSON Tools</a> 
      <span class="text-slate-600">/</span>
      <span class="text-slate-200">JSON to Zod</span>
    </Fragment>

    <div class="mb-8">
      <h1 class="text-3xl font-extrabold text-white mb-2">JSON to Zod Schema</h1>
      <p class="text-slate-400">
        Paste a JSON object to generate the equivalent 
        <a href="https://zod.dev" target="_blank" class="text-indigo-400 hover:underline">Zod</a> 
        validation schema for TypeScript.
      </p>
    </div>

    {/* ── CONTEXTUAL UPSELL (Moved to the top!) ── */}
    <ExtensionPromo context="JSON to Zod" />

    <JsonConverter client:idle />

    {/* Informational Card */}
    <div class="mt-16 border-t border-slate-800 pt-12">
      <div class="bg-slate-900/30 border border-slate-800 rounded-2xl p-8 max-w-3xl">
        <h2 class="text-xl font-bold text-white mb-4">Why use Zod?</h2>
        <p class="text-slate-400 leading-relaxed">
          TypeScript validates types at compile time, but Zod validates data at <strong>runtime</strong>. This is crucial when working with external APIs where the data shape might be unpredictable.
        </p>
      </div>
    </div>

    {/* 4. Render the visible HTML perfectly synced with the Schema */}
    <HowToSection howTo={pageSeoData?.howTo} />
    <FaqSection faqs={pageSeoData?.faqs} />
    
    <RelatedTools currentTool="json-to-zod" /> 
  </div>
</Layout>