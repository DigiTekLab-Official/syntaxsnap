---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import ToolCard from '../components/ui/ToolCard.astro';
import { TOOLS } from '../config/tools';
import { ShieldCheck, ArrowRight, Zap, Code2, Play, CheckCircle2 } from 'lucide-astro';
import { buildWebApplication, buildItemList, SITE_URL } from '../utils/schema';

// SEO: WebApplication — establishes SyntaxSnap as a platform
const webAppSchema = buildWebApplication();

// SEO: ItemList — helps Google understand the full tool inventory
const itemListSchema = buildItemList(
  TOOLS.map(t => ({ name: t.title, url: `${SITE_URL}${t.href}` }))
);

// ── Triple-Lock Branding Schemas ────────────────────────────────
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "SyntaxSnap",
  "alternateName": ["Syntax Snap", "DigiTekLab SyntaxSnap"],
  "url": "https://syntaxsnap.com/"
};

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "SyntaxSnap",
  "url": "https://syntaxsnap.com/",
  "logo": {
    "@type": "ImageObject",
    "url": "https://syntaxsnap.com/logo.png",
    "width": 512,
    "height": 512
  }
};
---

<Layout 
  title="SyntaxSnap – Privacy-First Developer Tools to Generate Code Instantly"
  isHomepage={true}
>
  {/* 1. Site Name & Identity */}
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  
  {/* 2. Platform & Inventory Schemas */}
  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  {/* Hero Section */}
  <div class="pt-16 pb-12 px-4 max-w-7xl mx-auto">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-12">
      
      {/* Left Column: The Pitch */}
      <div class="flex-1 max-w-2xl text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-900/50 border border-slate-700 text-slate-300 text-sm font-medium mb-6 animate-fade-in">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
          </span>
          100% Client-Side Processing
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white tracking-tight mb-6 leading-tight">
          Free Developer Tools to <br class="hidden md:block" />
          <span class="text-transparent bg-clip-text bg-linear-to-r from-indigo-400 to-cyan-400">Generate Code Instantly.</span>
        </h1>

        <p class="text-lg text-slate-300 mb-8 leading-relaxed max-w-lg mx-auto lg:mx-0">
          Convert JSON to Zod, generate mock APIs, and build Tailwind v4 gradients in seconds. <strong>No servers. No tracking. Your data never leaves the browser.</strong>
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4 mb-8">
          <a href="/tools/json-schema-to-zod" class="flex items-center gap-2 px-6 py-3 rounded-xl bg-indigo-600 hover:bg-indigo-700 text-white font-bold transition-all shadow-[0_0_20px_rgba(79,70,229,0.3)] hover:shadow-[0_0_30px_rgba(79,70,229,0.5)]">
            <Play class="w-5 h-5 fill-current" />
            Try the Zod Generator
          </a>
          <a href="#all-tools" class="flex items-center gap-2 px-6 py-3 rounded-xl bg-slate-800 hover:bg-slate-700 text-white font-medium border border-slate-700 transition-all">
            View All {TOOLS.length} Tools
          </a>
        </div>

        {/* The "Use Case Hooks" (NEW) */}
        <div class="pt-4 border-t border-slate-800/60 max-w-lg mx-auto lg:mx-0">
          <p class="text-xs text-slate-500 uppercase tracking-wider font-semibold mb-3">Built specifically for:</p>
          <div class="flex flex-wrap items-center justify-center lg:justify-start gap-3 text-sm text-slate-300 font-medium">
            <span class="flex items-center gap-1.5 bg-slate-900/50 px-3 py-1.5 rounded-lg border border-slate-800"><CheckCircle2 class="w-4 h-4 text-indigo-400" /> TypeScript Engineers</span>
            <span class="flex items-center gap-1.5 bg-slate-900/50 px-3 py-1.5 rounded-lg border border-slate-800"><CheckCircle2 class="w-4 h-4 text-cyan-400" /> API Developers</span>
            <span class="flex items-center gap-1.5 bg-slate-900/50 px-3 py-1.5 rounded-lg border border-slate-800"><CheckCircle2 class="w-4 h-4 text-emerald-400" /> Frontend Teams</span>
          </div>
        </div>
      </div>

      {/* Right Column: The "Aha!" Moment Visual */}
      <div class="flex-1 w-full max-w-2xl relative group perspective mt-8 lg:mt-0">
        <div class="absolute -inset-1 bg-linear-to-r from-indigo-500 to-cyan-500 rounded-2xl blur opacity-20 group-hover:opacity-40 transition duration-1000 group-hover:duration-200"></div>
        <div class="relative rounded-xl bg-slate-900 border border-slate-800 shadow-2xl overflow-hidden transform transition-transform duration-500 group-hover:scale-[1.02]">
          
          {/* Mock Browser Header */}
          <div class="flex items-center px-4 py-3 border-b border-slate-800 bg-slate-950">
            <div class="flex space-x-2">
              <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
            </div>
            <div class="mx-auto text-xs text-slate-500 font-mono flex items-center gap-2">
              <ShieldCheck class="w-3 h-3 text-emerald-500" /> local-environment
            </div>
          </div>

          {/* Mock Editor Content */}
          <div class="grid grid-cols-2 divide-x divide-slate-800 bg-[#0d1117] font-mono text-xs sm:text-sm">
            {/* Input Side */}
            <div class="p-4 h-64 overflow-hidden">
              <div class="text-slate-500 mb-2 text-xs uppercase tracking-wider">Input: JSON</div>
              <pre class="text-cyan-300"><code>{`{
  "user": {
    "id": 1,
    "name": "Alice",
    "email": "alice@example.com",
    "isActive": true
  }
}`}</code></pre>
            </div>
            {/* Output Side */}
            <div class="p-4 h-64 overflow-hidden bg-[#0a0d12]">
              <div class="text-indigo-400 mb-2 text-xs uppercase tracking-wider flex items-center justify-between">
                <span>Output: Zod Schema</span>
                <span class="flex h-2 w-2 relative">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
                </span>
              </div>
              <pre class="text-emerald-300"><code>{`const userSchema = z.object({
  user: z.object({
    id: z.number(),
    name: z.string(),
    email: z.string().email(),
    isActive: z.boolean()
  })
});`}</code></pre>
            </div>
          </div>
          
          {/* Mock Footer Action */}
          <div class="p-3 bg-slate-950 border-t border-slate-800 text-center">
             <a href="/tools/json-schema-to-zod" class="text-sm text-indigo-400 hover:text-indigo-300 font-medium inline-flex items-center gap-1 transition-colors">
               Run this generator live <ArrowRight class="w-4 h-4" />
             </a>
          </div>

        </div>
      </div>

    </div>
  </div>
  <div class="max-w-6xl mx-auto px-4 mt-8 mb-16">
  <p class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-4">🔥 Trending Tools Today</p>
  <div class="flex flex-wrap gap-4">
    <a href="/tools/aurora-gradient" class="bg-indigo-500/10 hover:bg-indigo-500/20 text-indigo-300 border border-indigo-500/20 px-4 py-2 rounded-full text-sm font-medium transition-colors">
      Aurora Gradient Generator
    </a>
    <a href="/tools/env-to-zod" class="bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-300 border border-emerald-500/20 px-4 py-2 rounded-full text-sm font-medium transition-colors">
      Env to Zod Converter
    </a>
    <a href="/tools/dockerfile-generator" class="bg-blue-500/10 hover:bg-blue-500/20 text-blue-300 border border-blue-500/20 px-4 py-2 rounded-full text-sm font-medium transition-colors">
      Multi-Stage Dockerfile Generator
    </a>
  </div>
</div>

  <div class="w-full h-px bg-linear-to-r from-transparent via-slate-800 to-transparent my-12"></div>

  {/* SEO Content Block (Moved UP for Better Crawling) */}
  <article class="max-w-4xl mx-auto px-4 text-center mb-16">
    <h2 class="text-3xl font-bold text-white mb-4">A Complete Suite of Local Developer Utilities</h2>
    <p class="text-slate-400 text-lg leading-relaxed">
      Stop pasting sensitive production data into random online formatters. SyntaxSnap provides a robust collection of utilities that run entirely in your browser's JavaScript engine. From <strong>TypeScript interface generation</strong> to <strong>JWT debugging</strong> and <strong>Tailwind CSS tools</strong>, your code stays strictly on your machine.
    </p>
  </article>

  {/* Tools Grid */}
  <div id="all-tools" class="max-w-6xl mx-auto px-4 pb-12">
    <div class="flex items-center justify-between mb-8 border-b border-slate-800 pb-4">
      <h2 class="text-2xl font-bold text-white flex items-center gap-2"><Code2 class="w-6 h-6 text-indigo-400" /> All Available Tools</h2>
      <span class="hidden sm:inline-block px-3 py-1 rounded-full bg-slate-900 border border-slate-800 text-sm text-slate-400 font-medium">{TOOLS.length} tools available locally</span>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {TOOLS.map((tool) => (
        <ToolCard tool={tool} />
      ))}
    </div>
  </div>

  <div class="w-full h-px bg-linear-to-r from-transparent via-slate-800 to-transparent my-8"></div>

  {/* Bottom Info / Tool Categories */}
  <article class="max-w-6xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-white mb-6">Explore by Category</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="p-5 rounded-xl bg-slate-900/30 border border-slate-800 hover:bg-slate-900/50 transition-colors">
        <h3 class="font-semibold mb-2"><a href="/tools/category/json" class="text-indigo-400 hover:text-indigo-300 transition-colors flex items-center gap-2">JSON & Schema <ArrowRight class="w-4 h-4" /></a></h3>
        <p class="text-slate-400 text-sm leading-relaxed">Convert between JSON, Zod, TypeScript interfaces, JSON Schema, and OpenAPI specs. Perfect for building type-safe API integrations.</p>
      </div>
      <div class="p-5 rounded-xl bg-slate-900/30 border border-slate-800 hover:bg-slate-900/50 transition-colors">
        <h3 class="font-semibold mb-2"><a href="/tools/category/css" class="text-indigo-400 hover:text-indigo-300 transition-colors flex items-center gap-2">CSS & Design <ArrowRight class="w-4 h-4" /></a></h3>
        <p class="text-slate-400 text-sm leading-relaxed">Generate aurora gradients, glassmorphism effects, mesh gradients, and Tailwind shadows — then copy production-ready CSS in one click.</p>
      </div>
      <div class="p-5 rounded-xl bg-slate-900/30 border border-slate-800 hover:bg-slate-900/50 transition-colors">
        <h3 class="font-semibold mb-2"><a href="/tools/category/dev" class="text-indigo-400 hover:text-indigo-300 transition-colors flex items-center gap-2">Developer Utilities <ArrowRight class="w-4 h-4" /></a></h3>
        <p class="text-slate-400 text-sm leading-relaxed">Debug JWTs, compare diffs, test regex, describe cron schedules, convert SVG to JSX, and generate Dockerfiles — all offline.</p>
      </div>
    </div>
  </article>
</Layout>